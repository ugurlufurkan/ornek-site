{
  "name": "ornek-site",
  "version": "1.0.0",
  "description": "Kavrulmuş premium kahve e-ticaret sitesi — Express, PostgreSQL, Drizzle ORM, vanilla frontend",
  "main": "server.js",
  "scripts": {
  "start": "node db/migrate.js && node seed.js && node server.js",
  "dev": "docker compose -f docker-compose.dev.yml up -d --wait && node server.js",
  "prod": "docker compose -f docker-compose.prod.yml up -d --build",
  "prod:down": "docker compose -f docker-compose.prod.yml down",
  "dev:down": "docker compose -f docker-compose.dev.yml down",
  "seed": "node seed.js",
  "db:generate": "drizzle-kit generate",
  "db:migrate": "node db/migrate.js",
  "db:studio": "drizzle-kit studio"
},
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "jsonwebtoken": "^9.0.3",
    "nodemailer": "^9.0.3",
    "pg": "^8.22.0"
  },
  "devDependencies": {
    "drizzle-kit": "^0.31.10"
  }
}
